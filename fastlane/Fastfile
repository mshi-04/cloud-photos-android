default_platform(:android)

platform :android do
  def dev_properties
    {
      "DEV_API_BASE_URL" => ENV["DEV_API_BASE_URL"],
      "DEV_COGNITO_CLIENT_ID" => ENV["DEV_COGNITO_CLIENT_ID"],
      "DEV_S3_BUCKET_NAME" => ENV["DEV_S3_BUCKET_NAME"]
    }.compact
  end

  def prod_properties
    {
      "PROD_API_BASE_URL" => ENV["PROD_API_BASE_URL"],
      "PROD_COGNITO_CLIENT_ID" => ENV["PROD_COGNITO_CLIENT_ID"],
      "PROD_S3_BUCKET_NAME" => ENV["PROD_S3_BUCKET_NAME"]
    }.compact
  end

  desc "Run Unit Tests (used in CI)"
  lane :test do
    gradle(task: "test", flavor: "Dev", build_type: "Debug", properties: dev_properties, print_command: false)
  end



  desc "Build the DEV environment APK (used in CD)"
  lane :build_dev do
    gradle(task: "assemble", flavor: "Dev", build_type: "Release", properties: dev_properties, print_command: false)
  end

  desc "Build the PROD environment APK and AAB (used in CD)"
  lane :build_prod do
    gradle(task: "assemble", flavor: "Prod", build_type: "Release", properties: prod_properties, print_command: false)
    gradle(task: "bundle", flavor: "Prod", build_type: "Release", properties: prod_properties, print_command: false)
  end
end